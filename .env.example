# SOC Platform Environment Configuration
# Copy this file to .env and customize for your deployment

# === Manager Server ===
MANAGER_HOST=127.0.0.1
MANAGER_PORT=9000

# === Security ===
# CRITICAL: Change these in production!
ENABLE_TLS=true
AUTH_SECRET_KEY=your-secret-key-here-change-this-in-production
API_KEY=your-api-key-for-dashboard-access
ENCRYPT_DB_FIELDS=true
DB_ENCRYPTION_KEY=your-database-encryption-key-change-this

# === TLS Certificates (auto-generated if not specified) ===
# TLS_CERT_FILE=certs/server.crt
# TLS_KEY_FILE=certs/server.key
# TLS_CA_FILE=certs/ca.crt

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
# true = auto-restart dashboard API when Python/HTML files change
DASHBOARD_AUTO_RELOAD=true

# === Dashboard Teacher Login Accounts ===
# Format: username:password,username2:password2
# Example:
# TEACHER_ACCOUNTS=teacher01:Lab@Teacher01,teacher02:Lab@Teacher02
# If not set, 9 default teacher accounts (teacher01..teacher09) are auto-created.
# TEACHER_ACCOUNTS=

# === Database ===
# DB_PATH=/path/to/soc_platform.db

# === Agent Configuration ===
AGENT_SEND_INTERVAL=1
AGENT_ID=agent-001
# AGENT_HOSTNAME=lab-pc-01  # Auto-detected if not set

# === Custom Log Sources (semicolon-separated) ===
# Linux example:
# LOG_SOURCES=/var/log/syslog;/var/log/auth.log;/var/log/custom.log
# Windows: Leave empty, Event Logs are auto-collected

# === File Integrity Monitoring Paths (semicolon-separated) ===
# Linux example:
# FIM_WATCH_PATHS=/etc/passwd;/etc/shadow;/etc/hosts;/etc/ssh/sshd_config
# Windows example:
# FIM_WATCH_PATHS=C:\Windows\System32\drivers\etc\hosts;C:\Windows\System32\config\SAM

# === Student Monitoring Features ===
MONITOR_BROWSER_HISTORY=true
MONITOR_ACTIVE_WINDOW=true
MONITOR_USB_DEVICES=true
MONITOR_SHELL_COMMANDS=true
MONITOR_PROCESSES=true
MONITOR_NETWORK=true

# === Privacy: Browser URL Filtering (semicolon-separated domains) ===
# Only collect URLs from these domains (empty = collect all)
# Example: github.com;stackoverflow.com;example.edu
BROWSER_ALLOWED_DOMAINS=

# === Data Retention (days) ===
LOG_RETENTION_DAYS=30
ALERT_RETENTION_DAYS=90
